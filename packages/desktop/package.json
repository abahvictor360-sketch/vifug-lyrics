{
  "name": "@template/desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "copy:web": "rm -rf web-dist && cp -r ../web/dist web-dist",
    "build": "bun run copy:web && vite build",
    "dist": "cd ../web && bun run build && cd ../desktop && bun run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/win32-x64-msvc": "0.5.29",
    "@neon-rs/load": "^0.0.4",
    "detect-libc": "2.0.2",
    "libsql": "0.5.29",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.15.0",
    "@types/node": "22",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
