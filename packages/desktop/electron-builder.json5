// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.vifug.lyrics",
  "asar": true,
  // Explicit so electron-builder never has to sniff node_modules for the
  // version — bun hoists electron to the workspace root, where detection
  // fails ("Cannot compute electron version"). Keep in sync with bun.lock.
  "electronVersion": "30.5.1",
  // The native NDI addon is N-API (ABI-stable) and is compiled explicitly in
  // CI, so electron-builder must NOT try to rebuild native deps against Electron
  // headers (that would need the NDI SDK at rebuild time and can fail). libsql
  // ships its own prebuilt binaries, so this is safe for it too.
  "npmRebuild": false,
  "asarUnpack": [
    "**/*.node",
    "node_modules/@libsql/**",
    "node_modules/libsql/**",
    // Native NDI sender: the .node is covered above, but its NDI runtime DLL
    // (Processing.NDI.Lib.*.dll) must be unpacked too or the addon can't load.
    "node_modules/@stagetimerio/grandiose/**",
    "node_modules/grandiose/**"
  ],
  "extraResources": [
    { "from": "../web/local.db", "to": "seed.db" }
  ],
  "productName": "Vifug Lyrics",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    "web-dist"
  ],
  "mac": {
    "icon": "build/icon.png",
    "target": [
      "dmg"
    ],
    // Version-independent name (no spaces): the landing page hardcodes
    // .../releases/latest/download/<name>, which must stay stable across
    // releases. The release tag carries the version.
    "artifactName": "VifugLyrics-Mac-Installer.${ext}"
  },
  "win": {
    "icon": "build/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "VifugLyrics-Windows-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "icon": "build/icon.png",
    "category": "AudioVideo",
    "target": [
      "AppImage"
    ],
    "artifactName": "VifugLyrics-Linux.${ext}"
  }
}
